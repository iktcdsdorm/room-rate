<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>一貫道崇德學院 · 宿舍管理中心</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, "Noto Sans TC", "Microsoft JhengHei", sans-serif; background: #f5f4f0; color: #1a1a1a; font-size: 15px; line-height: 1.7; }
.wrap { max-width: 780px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }
.hero { background: #0F6E56; color: white; padding: 2rem 1.5rem; border-radius: 14px; margin-bottom: 1.25rem; }
.hero-eyebrow { font-size: 12px; opacity: 0.7; margin-bottom: 4px; }
.hero h1 { font-size: 22px; font-weight: 600; margin-bottom: 6px; }
.hero-sub { font-size: 13px; opacity: 0.85; margin-bottom: 1rem; line-height: 1.7; }
.badge-row { display: flex; flex-wrap: wrap; gap: 6px; }
.badge { background: rgba(255,255,255,0.18); color: white; font-size: 12px; padding: 3px 10px; border-radius: 20px; }
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 1.25rem; }
.stat { background: white; border-radius: 10px; padding: 0.75rem 0.5rem; text-align: center; border: 0.5px solid #e0ddd5; }
.stat-n { font-size: 22px; font-weight: 600; color: #1D9E75; }
.stat-l { font-size: 11px; color: #888; margin-top: 2px; }
.sec-title { font-size: 15px; font-weight: 600; color: #1a1a1a; margin-bottom: 0.75rem; padding-bottom: 6px; border-bottom: 1.5px solid #1D9E75; }
.price-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 8px; margin-bottom: 1.5rem; }
.pc { background: white; border: 0.5px solid #e0ddd5; border-radius: 12px; padding: 1rem 1.1rem; }
.pc.green { border-color: #1D9E75; }
.pc.lavender { border-color: #9D97E8; background: #faf9ff; }
.pc.amber { border-color: #F5A623; background: #fffdf5; }
.p-type { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
.p-pax { font-size: 11px; color: #888; margin-bottom: 8px; }
.p-price { font-size: 24px; font-weight: 700; color: #1D9E75; }
.p-price .unit { font-size: 13px; color: #888; font-weight: 400; }
.p-price.purple { color: #7F77DD; }
.p-note { font-size: 11px; color: #888; margin-top: 4px; }
.meal-box { background: white; border: 0.5px solid #e0ddd5; border-radius: 12px; overflow: hidden; margin-bottom: 1rem; }
.meal-header { background: #0F6E56; color: white; padding: 0.65rem 1rem; font-size: 13px; font-weight: 600; }
.meal-row { display: flex; align-items: center; padding: 0.65rem 1rem; border-bottom: 0.5px solid #f0ede6; }
.meal-row:last-child { border-bottom: none; }
.meal-label { font-size: 14px; color: #333; flex: 1; }
.meal-who { font-size: 11px; color: #999; flex: 2; }
.meal-price { font-size: 18px; font-weight: 700; color: #1D9E75; min-width: 70px; text-align: right; }
.meal-price .unit { font-size: 12px; color: #999; font-weight: 400; }
.meal-note { padding: 0.5rem 1rem 0.65rem; font-size: 11px; color: #1D9E75; background: #f0faf5; }
.group-box { background: #FFF8EC; border: 0.5px solid #F5A623; border-radius: 12px; padding: 0.85rem 1rem; margin-bottom: 1.5rem; }
.group-title { font-size: 13px; font-weight: 600; color: #9A6200; margin-bottom: 6px; }
.group-body { font-size: 12px; color: #7A5010; line-height: 1.9; }
.room-card { background: white; border: 0.5px solid #e0ddd5; border-radius: 14px; overflow: hidden; margin-bottom: 12px; }
.room-card.green { border-color: #1D9E75; }
.room-card.purple { border-color: #9D97E8; }
.room-card.amber { border-color: #F5A623; }
.room-header { display: flex; align-items: center; gap: 12px; padding: 0.8rem 1rem; }
.room-header img.thumb { width: 80px; height: 60px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }
.room-meta { flex: 1; }
.room-name { font-size: 15px; font-weight: 600; margin-bottom: 2px; }
.room-price-line { font-size: 13px; color: #1D9E75; font-weight: 600; margin-bottom: 2px; }
.room-price-line.purple { color: #7F77DD; }
.room-price-line.amber { color: #B07414; }
.room-desc { font-size: 12px; color: #666; line-height: 1.6; }
.tag-row { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 6px; }
.tag { font-size: 11px; padding: 2px 8px; border-radius: 20px; }
.t-std { background: #f0ede6; color: #5a5a55; }
.t-bal { background: #dff2ea; color: #0a6040; }
.t-vip { background: #eeecfd; color: #3C3489; }
.t-din { background: #fdf0dc; color: #7A5010; }
.t-cnt { background: #f0ede6; color: #888; }
.t-inc { background: #dff2ea; color: #0a6040; }
.photo-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; padding: 0 0.85rem 0.85rem; }
.photo-item img { width: 100%; height: 95px; object-fit: cover; border-radius: 8px; display: block; }
.photo-grid-5 { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; padding: 0 0.85rem 0.85rem; }
.photo-grid-5 img { width: 100%; height: 90px; object-fit: cover; border-radius: 8px; display: block; }
.photo-grid-6 { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; padding: 0 0.85rem 0.85rem; }
.photo-grid-6 img { width: 100%; height: 90px; object-fit: cover; border-radius: 8px; display: block; }
.cap { font-size: 10px; color: #999; text-align: center; margin-top: 3px; }
.rules { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1.25rem; }
.rule-block { background: white; border-radius: 10px; padding: 0.85rem 1rem; border: 0.5px solid #e0ddd5; }
.rule-title { font-size: 13px; font-weight: 600; color: #0F6E56; margin-bottom: 6px; }
.rule-body { font-size: 13px; color: #555; line-height: 1.8; }
.bank { background: #dff2ea; border-radius: 12px; padding: 1.1rem 1.25rem; margin-bottom: 1.25rem; border: 0.5px solid #a8dcc3; }
.bank-title { font-size: 14px; font-weight: 600; color: #0a5c3f; margin-bottom: 10px; }
.bank-row { display: flex; gap: 10px; align-items: baseline; margin-bottom: 5px; }
.bank-label { font-size: 12px; color: #1D9E75; min-width: 62px; font-weight: 600; }
.bank-val { font-size: 14px; color: #0a5c3f; font-weight: 600; letter-spacing: 0.5px; }
.bank-note { font-size: 11px; color: #1D9E75; margin-top: 8px; }
.contact { background: white; border-radius: 12px; padding: 1.1rem 1.25rem; margin-bottom: 1.25rem; border: 0.5px solid #e0ddd5; }
.contact-title { font-size: 14px; font-weight: 600; margin-bottom: 8px; }
.contact-row { font-size: 13px; color: #555; margin-bottom: 4px; }
.footer { font-size: 12px; color: #999; text-align: center; padding-top: 1rem; border-top: 0.5px solid #e0ddd5; line-height: 1.8; }
@media(max-width:480px){
  .stats { grid-template-columns: repeat(2,1fr); }
  .price-grid { grid-template-columns: 1fr; }
  .photo-grid, .photo-grid-5, .photo-grid-6 { grid-template-columns: repeat(2,1fr); }
  .room-header img.thumb { width: 70px; height: 52px; }
  .meal-who { display: none; }
}
</style>
